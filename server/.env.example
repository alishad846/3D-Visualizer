# ScanVista API — copy to server/.env for local development

NODE_ENV=development
PORT=5000

# PostgreSQL (local Docker or Render external URL)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/db

# Must match your frontend origin (local Vite default)
CLIENT_URL=http://localhost:5173

JWT_SECRET=dev_scanvista_jwt_secret_change_me
JWT_REFRESH_SECRET=dev_scanvista_refresh_secret_change_me

# Supabase Storage (required for model/image uploads in production)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key
# Backward-compat fallback only. Prefer SUPABASE_SERVICE_ROLE_KEY for server uploads.
SUPABASE_KEY=optional-legacy-fallback

# Redis connection for rate limiting (local Docker/host port 6379, or Render connection URL)
REDIS_URL=redis://localhost:6379

# AI service connection URL (local FastAPI engine)
AI_SERVICE_URL=http://localhost:8000
